# Copy to .env and fill in. `export ` prefix is fine (python-dotenv handles it).
# NEVER put real keys in this file — it's committed. Real values go in .env (gitignored).

# --- Ingestion (stages 1-3, pull_videos.py) ---
export YOUTUBE_API_KEY=""              # Google Cloud -> YouTube Data API v3
export WEBSHARE_PROXY_USERNAME=""      # Webshare residential proxy
export WEBSHARE_PROXY_PASSWORD=""

# --- Embeddings (Voyage AI) ---
export VOYAGE_API_KEY=""               # https://dash.voyageai.com
# export VOYAGE_MODEL="voyage-3"       # default; 1024 dims (must match schema.sql)

# --- Vector store (Supabase) ---
export SUPABASE_URL="https://YOURPROJECT.supabase.co"
export SUPABASE_SERVICE_KEY=""         # Project Settings -> API -> service_role key (SECRET, backend only)

# --- Generation (Claude) ---
export ANTHROPIC_API_KEY=""            # https://console.anthropic.com
# export ANTHROPIC_MODEL="claude-sonnet-4-6"   # or claude-opus-4-8 for max quality

# --- Frontend (browser-safe; read by Vite) ---
export VITE_SUPABASE_URL="https://YOURPROJECT.supabase.co"
export VITE_SUPABASE_ANON_KEY=""       # anon/public key (role=anon) — safe for the browser
export VITE_API_URL=""                 # empty in dev; deployed API origin in prod

# --- Tuning (optional; defaults in config.py) ---
# export TOP_K="8"
# export DIRECT_THRESHOLD="0.56"
# export EXTRAPOLATE_THRESHOLD="0.45"
