# Copy to web/.env.local and fill in. These are browser-safe (anon key only).
VITE_SUPABASE_URL="https://YOURPROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY=""          # Supabase -> Project Settings -> API -> anon/public key

# Leave empty in dev (Vite proxies /chat to localhost:8000).
# In prod, point at your deployed API origin, e.g. https://api.yourapp.com
VITE_API_URL=""
